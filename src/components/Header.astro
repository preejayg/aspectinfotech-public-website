---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, BOOKING_LINK } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/#services">Services</HeaderLink>
			<HeaderLink href="/#assessment">Assessment</HeaderLink>
			<HeaderLink href="/#contact">Contact</HeaderLink>
		</div>
		<div class="cta-links">
			<a class="book" href={BOOKING_LINK}>Book free assessment</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0;
		padding: 0 1rem;
		backdrop-filter: blur(18px);
		background: rgba(255, 255, 255, 0.86);
		border-bottom: 1px solid rgba(var(--gray-light), 0.8);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		line-height: 1.2;
		max-width: 16rem;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1120px;
		margin: 0 auto;
	}
	.internal-links,
	.cta-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.book {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		background: rgb(var(--black));
		color: white;
		text-decoration: none;
		font-weight: 700;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}
	.book:hover {
		color: white;
		opacity: 0.9;
		transform: translateY(-1px);
	}
	@media (max-width: 860px) {
		nav {
			flex-wrap: wrap;
			justify-content: center;
			padding: 0.35rem 0;
		}
		h2 {
			width: 100%;
			max-width: none;
			text-align: center;
		}
	}
	@media (max-width: 720px) {
		.internal-links {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
		}
		.cta-links {
			width: 100%;
			justify-content: center;
			padding-bottom: 0.5rem;
		}
	}
</style>
