---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, BOOKING_LINK } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/#offers">Offers</HeaderLink>
			<HeaderLink href="/#assessment">Assessment</HeaderLink>
			<HeaderLink href="/#contact">Contact</HeaderLink>
		</div>
		<div class="cta-links">
			<a class="book" href={BOOKING_LINK} target="_blank" rel="noreferrer">Book assessment</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0 1rem;
		backdrop-filter: blur(18px);
		background: rgba(255, 255, 255, 0.78);
		border-bottom: 1px solid rgba(216, 225, 239, 0.85);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		line-height: 1.2;
		max-width: 15rem;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(1120px, calc(100% - 0.5rem));
		margin: 0 auto;
		min-height: 74px;
	}
	.internal-links {
		display: flex;
		gap: 1.25rem;
		align-items: center;
		flex: 1;
		justify-content: center;
	}
	.cta-links {
		display: flex;
		align-items: center;
	}
	.book {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		background: rgb(var(--black));
		color: white;
		font-weight: 700;
		text-decoration: none;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}
	.book:hover {
		opacity: 0.93;
		transform: translateY(-1px);
		color: white;
	}
	@media (max-width: 820px) {
		nav {
			flex-wrap: wrap;
			padding: 0.5rem 0;
			min-height: auto;
		}
		h2 {
			max-width: none;
			width: 100%;
		}
		.internal-links {
			justify-content: flex-start;
			width: 100%;
			gap: 1rem;
			flex-wrap: wrap;
		}
		.cta-links {
			width: 100%;
		}
		.book {
			width: 100%;
		}
	}
</style>
