---
import { CONTACT_EMAIL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div>
			<strong>Aspect Infotech</strong>
			<p>Digital workplace solutions for Australian small businesses.</p>
		</div>
		<div>
			<p><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
			<p>Australia</p>
		</div>
	</div>
	<div class="copyright">&copy; {today.getFullYear()} Aspect Infotech. All rights reserved.</div>
</footer>
<style>
	footer {
		padding: 3rem 1rem 4rem;
		background: transparent;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-inner {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		max-width: 1120px;
		margin: 0 auto 1rem;
		text-align: left;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(216, 225, 239, 0.9);
	}
	.footer-inner strong {
		font-size: 1.1rem;
		color: rgb(var(--black));
	}
	.footer-inner p {
		margin: 0.35rem 0 0;
	}
	.copyright {
		font-size: 0.92rem;
	}
	a {
		color: var(--accent);
		text-decoration: none;
	}
	a:hover {
		text-decoration: underline;
	}
	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
		}
	}
</style>
