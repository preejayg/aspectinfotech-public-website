---
import { CONTACT_EMAIL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div>
			<strong>Aspect Infotech</strong>
			<p>Digital workplace solutions for growing Australian businesses.</p>
		</div>
		<div>
			<p><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
			<p>Based in Australia</p>
		</div>
	</div>
	<div class="copyright">&copy; {today.getFullYear()} Aspect Infotech. All rights reserved.</div>
</footer>
<style>
	footer {
		padding: 3rem 1rem 4rem;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-inner {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		max-width: 1120px;
		margin: 0 auto 1rem;
		text-align: left;
	}
	.footer-inner strong {
		font-size: 1.1rem;
		color: rgb(var(--black));
	}
	.footer-inner p {
		margin: 0.4rem 0 0;
	}
	footer a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	footer a:hover {
		text-decoration: underline;
	}
	.copyright {
		font-size: 0.95rem;
		margin-top: 2rem;
	}
	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			text-align: center;
		}
	}
</style>
